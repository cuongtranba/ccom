---
import AsciinemaPlayer from './AsciinemaPlayer.astro';
---

<div class="network-demo">
  <canvas id="propagation-viz" width="550" height="550" aria-label="Neural propagation network — interactive demo showing how changes cascade through connected inventory items"></canvas>

  <div class="demo-panel">
    <div class="demo-buttons">
      <button class="demo-btn" data-action="verify">verify all</button>
      <button class="demo-btn" data-action="change">cuong-node changes story</button>
      <button class="demo-btn" data-action="reverify">re-verify chain</button>
      <button class="demo-btn" data-action="reset">reset</button>
    </div>
    <pre class="demo-terminal" id="demo-output" aria-live="polite"><span class="prompt">$</span> <span class="cmd">inv node list --project clinic-checkin</span>
<span class="out">ID        NAME              OWNER
0fb8353f  cuong-node        cuong
de061a81  phong-node        phong
5447c4b6  duke-node         duke
a3b2c1d0  blue-node         blue</span>

<span class="prompt">$</span> <span class="cmd">inv item list --node 0fb8353f</span>
<span class="out">ID        KIND      TITLE                    STATUS</span>
<span class="out">e8def515  api-spec  API-001: POST /check-in  </span><span class="s-proven">proven</span>
<span class="out">c65ae3eb  adr       ADR-001: WebSocket sync  </span><span class="s-proven">proven</span>

<span class="prompt">$</span> <span class="cmd">_</span></pre>
  </div>

  <div class="cast-companion">
    <AsciinemaPlayer
      src="/casts/cross-node-signal.cast"
      title="cuong-node marks PRD suspect — signals cascade to phong-node, duke-node, blue-node"
      rows={20}
      cols={92}
      speed={1}
      idleTimeLimit={3}
      autoPlay={false}
    />
  </div>
</div>

<script>
  import '../scripts/propagation-demo.ts';
  import '../scripts/asciinema-init.ts';
</script>

<style>
  .network-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-top: 3rem;
  }

  #propagation-viz {
    width: 100%;
    aspect-ratio: 1;
    max-width: 550px;
  }

  .cast-companion {
    grid-column: 1 / -1;
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .network-demo { grid-template-columns: 1fr; }
    #propagation-viz { max-width: 100%; }
  }
</style>
