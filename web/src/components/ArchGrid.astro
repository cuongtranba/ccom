---
interface Card {
  icon: string;
  title: string;
  description: string;
}

const cards: Card[] = [
  { icon: 'LAYER:NEURAL', title: 'Signal Propagation', description: 'When an item changes, signals travel through traces automatically. Every dependent item across every node becomes suspect. No manual tracking. The network knows.' },
  { icon: 'LAYER:SOCIAL', title: 'Network Queries', description: "When AI doesn't understand context, it asks the network. Other nodes — human or AI — respond. Knowledge flows where it's needed, not where it's stored." },
  { icon: 'LAYER:CONSENSUS', title: 'Change Requests + Voting', description: 'Cross-inventory changes require consensus. Affected nodes vote. AI participates with reasons. No change lands without agreement.' },
  { icon: 'INTERFACE:CLI', title: 'Human Interface', description: 'Cobra-powered CLI for humans. inv node, inv item, inv trace, inv verify, inv impact, inv audit, inv cr, inv ask.' },
  { icon: 'INTERFACE:MCP', title: 'AI Interface', description: 'MCP server for Claude and other AI agents. Same engine, same state, same network. AI is a first-class participant, not an afterthought.' },
  { icon: 'ENGINE:GO', title: 'Core Engine', description: 'Go + SQLite + pumped-go. State machine with 5 transitions. Trace graph with recursive impact analysis. Built to be embedded, extended, and connected.' },
];
---

<div class="arch-grid">
  {cards.map(card => (
    <div class="arch-card">
      <div class="arch-card-icon">{card.icon}</div>
      <h3>{card.title}</h3>
      <p>{card.description}</p>
    </div>
  ))}
</div>

<style>
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .arch-card {
    padding: 2rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    transition: border-color 0.3s ease;
  }

  .arch-card:hover { border-color: var(--border-hover); }

  .arch-card-icon {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--signal-pulse);
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .arch-card h3 {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .arch-card p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
  }
</style>
