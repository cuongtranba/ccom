---
import AsciinemaPlayer from './AsciinemaPlayer.astro';
---

<div class="governance-demo">
  <div class="cr-lifecycle" id="cr-lifecycle">
    <div class="cr-header">
      <span class="cr-badge draft" id="cr-badge">DRAFT</span>
      <span class="cr-id">CR-042</span>
    </div>
    <h3 class="cr-title">Change check-in API from sync to async</h3>
    <p class="cr-proposer">Proposed by: <strong>phong-node</strong></p>
    <div class="cr-votes" id="cr-votes"></div>
    <div class="cr-quorum" id="cr-quorum">
      <div class="quorum-bar">
        <div class="quorum-fill" id="quorum-fill" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="3" aria-label="Human vote quorum progress"></div>
      </div>
      <span class="quorum-text" id="quorum-text">0/3 human votes (need &gt;50%)</span>
    </div>
  </div>

  <div class="demo-panel">
    <div class="demo-buttons">
      <button class="demo-btn" data-gov="draft">draft</button>
      <button class="demo-btn" data-gov="open">open voting</button>
      <button class="demo-btn" data-gov="vote">cast votes</button>
      <button class="demo-btn" data-gov="approve">approve</button>
      <button class="demo-btn" data-gov="archive">archive</button>
      <button class="demo-btn" data-gov="reset">reset</button>
    </div>
    <pre class="demo-terminal" id="gov-output" aria-live="polite"><span class="prompt">$</span> <span class="cmd">inv cr show CR-042</span>
<span class="out">CR-042  Change check-in API from sync to async
Status: </span><span class="s-muted">DRAFT</span>
<span class="out">Votes:  none</span>

<span class="prompt">$</span> <span class="cmd">_</span></pre>
  </div>

  <div class="cast-companion">
    <AsciinemaPlayer
      src="/casts/governance-vote.cast"
      title="phong-node proposes WebSocket switch — cuong-node approves, blue-node rejects, tally shown"
      rows={22}
      cols={92}
      speed={1}
      idleTimeLimit={3}
      autoPlay={false}
    />
  </div>
</div>

<script>
  import '../scripts/governance-lifecycle.ts';
  import '../scripts/asciinema-init.ts';
</script>

<style>
  .governance-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-top: 3rem;
  }

  /* ---- CR Card ---- */
  .cr-lifecycle {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: clamp(2rem, 3vw, 3rem);
    transition: border-color 0.4s ease, opacity 0.4s ease, box-shadow 0.4s ease;
  }

  .cr-lifecycle.approved {
    border-color: var(--proven);
    box-shadow: 0 0 20px color-mix(in oklch, var(--proven) 25%, transparent);
  }

  .cr-lifecycle.archived {
    opacity: 0.45;
    border-color: var(--text-muted);
  }

  .cr-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .cr-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .cr-badge.draft {
    background: color-mix(in oklch, var(--unverified) 15%, transparent);
    color: var(--unverified);
    border: 1px solid color-mix(in oklch, var(--unverified) 30%, transparent);
  }

  .cr-badge.voting {
    background: color-mix(in oklch, var(--proven) 15%, transparent);
    color: var(--proven);
    border: 1px solid color-mix(in oklch, var(--proven) 30%, transparent);
  }

  .cr-badge.approved {
    background: color-mix(in oklch, var(--proven) 25%, transparent);
    color: var(--proven);
    border: 1px solid color-mix(in oklch, var(--proven) 50%, transparent);
  }

  .cr-badge.archived {
    background: color-mix(in oklch, var(--text-muted) 15%, transparent);
    color: var(--text-muted);
    border: 1px solid color-mix(in oklch, var(--text-muted) 30%, transparent);
  }

  .cr-id {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .cr-title {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .cr-proposer {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cr-proposer strong {
    color: var(--text-secondary);
  }

  /* ---- Votes ---- */
  .cr-votes {
    min-height: 0;
  }

  .cr-votes :global(.vote-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.85rem;
    animation: voteSlideIn 0.4s ease forwards;
  }

  @keyframes voteSlideIn {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .cr-votes :global(.vote-node) {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    min-width: 100px;
    flex-shrink: 0;
  }

  .cr-votes :global(.vote-icon) {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .cr-votes :global(.vote-icon.approve) {
    color: var(--proven);
  }

  .cr-votes :global(.vote-icon.revise) {
    color: var(--suspect);
  }

  .cr-votes :global(.vote-reason) {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
    flex: 1;
  }

  .cr-votes :global(.vote-ai-tag) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.15rem 0.4rem;
    background: color-mix(in oklch, var(--signal-pulse) 10%, transparent);
    color: var(--signal-pulse);
    border-radius: 2px;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .cr-votes :global(.vote-advisory) {
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* ---- Quorum ---- */
  .cr-quorum {
    display: none;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-subtle);
  }

  .cr-quorum.visible {
    display: block;
  }

  .quorum-bar {
    height: 6px;
    background: var(--bg-deep);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .quorum-fill {
    height: 100%;
    width: 0%;
    background: var(--proven);
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .quorum-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .cast-companion {
    grid-column: 1 / -1;
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .governance-demo { grid-template-columns: 1fr; }
  }
</style>
